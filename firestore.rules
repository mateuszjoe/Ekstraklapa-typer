rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function googleSignedIn() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider == 'google.com'
        && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return googleSignedIn() && request.auth.token.email == 'mateuszjoe@gmail.com';
    }

    function isSeasonParticipant() {
      return googleSignedIn()
        && exists(/databases/$(database)/documents/seasons/2026-27/participants/$(request.auth.uid));
    }

    function matchOpen(seasonId, matchId) {
      return seasonId == '2026-27'
        && exists(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId))
        && get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.matchday is int
        && get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.matchday >= 1
        && get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.matchday <= 17
        && request.time < get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.closesAt;
    }

    function matchRevealed(seasonId, matchId) {
      return seasonId == '2026-27'
        && exists(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId))
        && get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.matchday is int
        && get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.matchday >= 1
        && get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.matchday <= 17
        && request.time >= get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.revealsAt;
    }

    function validOwnPrediction(predictionId) {
      return googleSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.matchId is string
        && predictionId == request.auth.uid + '_' + request.resource.data.matchId
        && request.resource.data.pick in ['1', 'X', '2']
        && request.resource.data.updatedAt == request.time
        && matchOpen('2026-27', request.resource.data.matchId)
        && request.resource.data.keys().hasOnly(['uid', 'matchId', 'pick', 'updatedAt']);
    }

    function validPlayerPick() {
      return request.resource.data.pick in ['1', 'X', '2']
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly(['pick', 'updatedAt']);
    }

    function validTrustedMatch(seasonId, matchId) {
      return seasonId == '2026-27'
        && matchId.size() > 0
        && matchId.size() <= 180
        && request.resource.data.matchday is int
        && request.resource.data.matchday >= 1
        && request.resource.data.matchday <= 17
        && request.resource.data.closesAt is timestamp
        && request.resource.data.revealsAt is timestamp
        && request.resource.data.revealsAt == request.resource.data.closesAt
        && request.resource.data.get('result', '') in ['', '1', 'X', '2']
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly(['matchday', 'closesAt', 'revealsAt', 'result', 'updatedAt']);
    }

    function validScheduleMeta(seasonId) {
      return seasonId == '2026-27'
        && request.resource.data.seasonId == seasonId
        && request.resource.data.signature is string
        && request.resource.data.signature.size() > 0
        && request.resource.data.signature.size() <= 100000
        && request.resource.data.matchCount is int
        && request.resource.data.matchCount > 0
        && request.resource.data.matchCount <= 153
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly(['seasonId', 'signature', 'matchCount', 'updatedAt']);
    }

    function validAvatar() {
      return request.resource.data.avatarType in ['google', 'club', 'stock', 'upload']
        && request.resource.data.avatarValue is string
        && request.resource.data.avatarValue.size() <= 180000
        && (
          (request.resource.data.avatarType == 'google' && request.resource.data.avatarValue == '')
          || (request.resource.data.avatarType == 'club' && request.resource.data.avatarValue in [
            'cracovia', 'gks-katowice', 'gornik-zabrze', 'jagiellonia', 'korona', 'lech',
            'legia', 'motor', 'piast', 'pogon', 'radomiak', 'rakow', 'slask', 'widzew',
            'wieczysta', 'wisla-krakow', 'wisla-plock', 'zaglebie'
          ])
          || (request.resource.data.avatarType == 'stock' && request.resource.data.avatarValue in [
            'bananowy-drybler', 'goat-osiedlowy', 'sedzia-var', 'krol-murawy',
            'kibic-incognito', 'magik-pilki', 'snajper-pola-karnego', 'numer-jeden',
            'mur-obrony', 'boiskowy-strateg', 'kapitan-druzyny', 'motor-napedowy',
            'joker-z-lawki', 'glos-trybun', 'weteran-sektora', 'szybkie-skrzydlo',
            'profesor-futbolu', 'talizman-druzyny'
          ])
          || (request.resource.data.avatarType == 'upload'
            && request.resource.data.avatarValue.matches('^data:image/(webp|jpeg);base64,[A-Za-z0-9+/=]+$'))
        );
    }

    function validDisplayName() {
      return request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.displayName.matches('^[^\\n\\r\\t]{1,40}$')
        && request.resource.data.displayName.matches('.*[^ ].*');
    }

    function validOwnProfile(uid) {
      return googleSignedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && validDisplayName()
        && request.resource.data.joinedAt is timestamp
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly([
          'uid', 'displayName', 'avatarType', 'avatarValue', 'joinedAt', 'updatedAt'
        ])
        && validAvatar();
    }

    function validChatMessage() {
      return isSeasonParticipant()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000
        && request.resource.data.image is string
        && request.resource.data.image.size() <= 90000
        && (request.resource.data.image == ''
          || request.resource.data.image.matches('^data:image/(webp|jpeg);base64,[A-Za-z0-9+/=]+$'))
        && (request.resource.data.text.size() > 0 || request.resource.data.image.size() > 0)
        && request.resource.data.replyToId is string
        && request.resource.data.replyToId.size() <= 100
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasOnly(['uid', 'text', 'image', 'replyToId', 'createdAt']);
    }

    function validChatReaction(reactionId) {
      return isSeasonParticipant()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.msgId is string
        && request.resource.data.msgId.size() > 0
        && request.resource.data.msgId.size() <= 100
        && reactionId == request.resource.data.msgId + '_' + request.auth.uid
        && exists(/databases/$(database)/documents/chat/$(request.resource.data.msgId))
        && request.resource.data.emoji in ['👍', '❤️', '😂', '😮', '😢', '🔥']
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly(['uid', 'msgId', 'emoji', 'updatedAt']);
    }

    function validChatRead(uid) {
      return isSeasonParticipant()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.lastReadAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly(['uid', 'lastReadAt', 'updatedAt']);
    }

    function validChatReaderCursor(authorUid, readerUid) {
      return isSeasonParticipant()
        && readerUid == request.auth.uid
        && authorUid != readerUid
        && request.resource.data.authorUid == authorUid
        && request.resource.data.readerUid == readerUid
        && request.resource.data.lastReadMessageId is string
        && request.resource.data.lastReadMessageId.size() > 0
        && request.resource.data.lastReadMessageId.size() <= 100
        && request.resource.data.lastReadAt is timestamp
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly([
          'authorUid', 'readerUid', 'lastReadMessageId', 'lastReadAt', 'updatedAt'
        ])
        && exists(/databases/$(database)/documents/chat/$(request.resource.data.lastReadMessageId))
        && get(/databases/$(database)/documents/chat/$(request.resource.data.lastReadMessageId)).data.uid == authorUid
        && get(/databases/$(database)/documents/chat/$(request.resource.data.lastReadMessageId)).data.createdAt
          == request.resource.data.lastReadAt;
    }

    function validLeaderboardDocument(seasonId, uid) {
      return googleSignedIn()
        && seasonId == '2026-27'
        && uid == request.auth.uid
        && request.resource.data.uid == uid
        && validDisplayName()
        && validAvatar()
        && request.resource.data.points is int
        && request.resource.data.points >= 0
        && request.resource.data.points <= 153
        && request.resource.data.typed is int
        && request.resource.data.typed >= 0
        && request.resource.data.typed <= 153
        && request.resource.data.points <= request.resource.data.typed
        && request.resource.data.joinedAt is timestamp
        && request.resource.data.lastScoreMatchId is string
        && request.resource.data.lastScoreMatchId.size() <= 180
        && request.resource.data.settledMatchIds is list
        && request.resource.data.settledMatchIds.size() <= 153
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly([
          'uid', 'displayName', 'avatarType', 'avatarValue', 'points', 'typed',
          'joinedAt', 'lastScoreMatchId', 'settledMatchIds', 'updatedAt'
        ]);
    }

    function validLeaderboardCreate(seasonId, uid) {
      return validLeaderboardDocument(seasonId, uid)
        && existsAfter(/databases/$(database)/documents/seasons/$(seasonId)/participants/$(uid))
        && request.resource.data.joinedAt
          == getAfter(/databases/$(database)/documents/seasons/$(seasonId)/participants/$(uid)).data.joinedAt
        && request.resource.data.points == 0
        && request.resource.data.typed == 0
        && request.resource.data.lastScoreMatchId == ''
        && request.resource.data.settledMatchIds.size() == 0;
    }

    function validLeaderboardIdentityUpdate(seasonId, uid) {
      return validLeaderboardDocument(seasonId, uid)
        && isSeasonParticipant()
        && resource.data.uid == uid
        && request.resource.data.joinedAt == resource.data.joinedAt
        && request.resource.data.points == resource.data.points
        && request.resource.data.typed == resource.data.typed
        && request.resource.data.lastScoreMatchId == resource.data.lastScoreMatchId
        && request.resource.data.settledMatchIds == resource.data.settledMatchIds;
    }

    function validLeaderboardScoreUpdate(seasonId, uid) {
      return validLeaderboardDocument(seasonId, uid)
        && isSeasonParticipant()
        && resource.data.uid == uid
        && request.resource.data.displayName == resource.data.displayName
        && request.resource.data.avatarType == resource.data.avatarType
        && request.resource.data.avatarValue == resource.data.avatarValue
        && request.resource.data.joinedAt == resource.data.joinedAt
        && request.resource.data.typed == resource.data.typed + 1
        && request.resource.data.lastScoreMatchId.size() > 0
        && request.resource.data.settledMatchIds.size() == resource.data.settledMatchIds.size() + 1
        && request.resource.data.settledMatchIds.hasAll(resource.data.settledMatchIds)
        && request.resource.data.settledMatchIds.hasAny([request.resource.data.lastScoreMatchId])
        && !exists(/databases/$(database)/documents/seasons/$(seasonId)/players/$(uid)/scores/$(request.resource.data.lastScoreMatchId))
        && existsAfter(/databases/$(database)/documents/seasons/$(seasonId)/players/$(uid)/scores/$(request.resource.data.lastScoreMatchId))
        && request.resource.data.points == resource.data.points
          + getAfter(/databases/$(database)/documents/seasons/$(seasonId)/players/$(uid)/scores/$(request.resource.data.lastScoreMatchId)).data.points;
    }

    function validPlayerScore(seasonId, uid, matchId) {
      return isSeasonParticipant()
        && seasonId == '2026-27'
        && uid == request.auth.uid
        && request.resource.data.uid == uid
        && request.resource.data.matchId == matchId
        && request.resource.data.pick in ['1', 'X', '2']
        && request.resource.data.points is int
        && request.resource.data.points in [0, 1]
        && request.resource.data.settledAt == request.time
        && request.resource.data.keys().hasOnly(['uid', 'matchId', 'pick', 'points', 'settledAt'])
        && exists(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId))
        && get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.get('result', '') in ['1', 'X', '2']
        && exists(/databases/$(database)/documents/seasons/$(seasonId)/players/$(uid)/picks/$(matchId))
        && request.resource.data.pick
          == get(/databases/$(database)/documents/seasons/$(seasonId)/players/$(uid)/picks/$(matchId)).data.pick
        && request.resource.data.points
          == (request.resource.data.pick
            == get(/databases/$(database)/documents/seasons/$(seasonId)/matches/$(matchId)).data.result ? 1 : 0)
        && exists(/databases/$(database)/documents/seasons/$(seasonId)/leaderboard/$(uid))
        && getAfter(/databases/$(database)/documents/seasons/$(seasonId)/leaderboard/$(uid)).data.lastScoreMatchId == matchId
        && getAfter(/databases/$(database)/documents/seasons/$(seasonId)/leaderboard/$(uid)).data.settledMatchIds.hasAny([matchId])
        && getAfter(/databases/$(database)/documents/seasons/$(seasonId)/leaderboard/$(uid)).data.settledMatchIds.size()
          == get(/databases/$(database)/documents/seasons/$(seasonId)/leaderboard/$(uid)).data.settledMatchIds.size() + 1
        && getAfter(/databases/$(database)/documents/seasons/$(seasonId)/leaderboard/$(uid)).data.typed
          == get(/databases/$(database)/documents/seasons/$(seasonId)/leaderboard/$(uid)).data.typed + 1
        && getAfter(/databases/$(database)/documents/seasons/$(seasonId)/leaderboard/$(uid)).data.points
          == get(/databases/$(database)/documents/seasons/$(seasonId)/leaderboard/$(uid)).data.points
            + request.resource.data.points;
    }

    match /predictions/{predictionId} {
      allow read: if googleSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if validOwnPrediction(predictionId);
      allow update: if googleSignedIn()
        && resource.data.uid == request.auth.uid
        && validOwnPrediction(predictionId);
      allow delete: if false;
    }

    match /seasons/{seasonId}/players/{uid}/picks/{matchId} {
      allow get: if googleSignedIn()
        && (uid == request.auth.uid
          || (isSeasonParticipant() && matchRevealed(seasonId, matchId)));
      allow list: if googleSignedIn() && uid == request.auth.uid;
      allow create: if isSeasonParticipant()
        && uid == request.auth.uid
        && matchOpen(seasonId, matchId)
        && validPlayerPick();
      allow update: if isSeasonParticipant()
        && uid == request.auth.uid
        && matchOpen(seasonId, matchId)
        && validPlayerPick();
      allow delete: if false;
    }

    match /seasons/{seasonId}/players/{uid}/scores/{matchId} {
      allow get, list: if googleSignedIn() && seasonId == '2026-27' && uid == request.auth.uid;
      allow create: if validPlayerScore(seasonId, uid, matchId);
      allow update, delete: if false;
    }

    match /seasons/{seasonId}/leaderboard/{uid} {
      allow get: if googleSignedIn()
        && seasonId == '2026-27'
        && (uid == request.auth.uid || isSeasonParticipant());
      allow list: if isSeasonParticipant() && seasonId == '2026-27';
      allow create: if validLeaderboardCreate(seasonId, uid);
      allow update: if validLeaderboardIdentityUpdate(seasonId, uid)
        || validLeaderboardScoreUpdate(seasonId, uid);
      allow delete: if false;
    }

    match /seasons/{seasonId}/matches/{matchId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin() && validTrustedMatch(seasonId, matchId);
      allow delete: if false;
    }

    match /scheduleMeta/{seasonId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin() && validScheduleMeta(seasonId);
      allow delete: if false;
    }

    match /profiles/{uid} {
      allow get: if googleSignedIn()
        && (uid == request.auth.uid || isSeasonParticipant());
      allow list: if false;
      allow create: if validOwnProfile(uid)
        && request.resource.data.joinedAt == request.time;
      allow update: if validOwnProfile(uid)
        && request.resource.data.joinedAt == resource.data.get('joinedAt', request.time);
      allow delete: if false;
    }

    match /seasons/{seasonId}/participants/{uid} {
      allow get: if googleSignedIn() && seasonId == '2026-27' && uid == request.auth.uid;
      allow list: if isSeasonParticipant() && seasonId == '2026-27';
      allow create: if googleSignedIn()
        && seasonId == '2026-27'
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.seasonId == seasonId
        && request.resource.data.joinedAt == request.time
        && request.resource.data.keys().hasOnly(['uid', 'seasonId', 'joinedAt'])
        && (
          (!exists(/databases/$(database)/documents/seasonStats/$(seasonId))
            && getAfter(/databases/$(database)/documents/seasonStats/$(seasonId)).data.participantCount == 1)
          || (exists(/databases/$(database)/documents/seasonStats/$(seasonId))
            && getAfter(/databases/$(database)/documents/seasonStats/$(seasonId)).data.participantCount
              == get(/databases/$(database)/documents/seasonStats/$(seasonId)).data.participantCount + 1)
        );
      allow update, delete: if false;
    }

    match /seasonStats/{seasonId} {
      allow get: if seasonId == '2026-27';
      allow list: if false;
      allow create: if googleSignedIn()
        && seasonId == '2026-27'
        && request.resource.data.seasonId == seasonId
        && request.resource.data.participantCount == 1
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly(['seasonId', 'participantCount', 'updatedAt'])
        && !exists(/databases/$(database)/documents/seasons/$(seasonId)/participants/$(request.auth.uid))
        && existsAfter(/databases/$(database)/documents/seasons/$(seasonId)/participants/$(request.auth.uid));
      allow update: if googleSignedIn()
        && seasonId == '2026-27'
        && request.resource.data.seasonId == resource.data.seasonId
        && request.resource.data.participantCount == resource.data.participantCount + 1
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly(['seasonId', 'participantCount', 'updatedAt'])
        && !exists(/databases/$(database)/documents/seasons/$(seasonId)/participants/$(request.auth.uid))
        && existsAfter(/databases/$(database)/documents/seasons/$(seasonId)/participants/$(request.auth.uid));
      allow delete: if false;
    }

    match /chat/{messageId} {
      allow read: if isSeasonParticipant();
      allow create: if validChatMessage();
      allow update: if false;
      allow delete: if isAdmin()
        || (isSeasonParticipant() && resource.data.uid == request.auth.uid);
    }

    match /chatReactions/{reactionId} {
      allow read: if isSeasonParticipant();
      allow create: if validChatReaction(reactionId);
      allow update: if resource.data.uid == request.auth.uid
        && resource.data.msgId == request.resource.data.msgId
        && validChatReaction(reactionId);
      allow delete: if isAdmin()
        || (isSeasonParticipant() && (
          resource.data.uid == request.auth.uid
          || (resource.data.msgId is string
            && resource.data.msgId.size() > 0
            && resource.data.msgId.size() <= 100
            && exists(/databases/$(database)/documents/chat/$(resource.data.msgId))
            && get(/databases/$(database)/documents/chat/$(resource.data.msgId)).data.uid == request.auth.uid)
        ));
    }

    match /chatReads/{uid} {
      allow get: if isSeasonParticipant() && uid == request.auth.uid;
      allow list: if false;
      allow create: if validChatRead(uid);
      allow update: if resource.data.uid == request.auth.uid && validChatRead(uid);
      allow delete: if false;

      match /readers/{readerUid} {
        allow get: if isSeasonParticipant()
          && (request.auth.uid == uid || request.auth.uid == readerUid);
        allow list: if isSeasonParticipant() && request.auth.uid == uid;
        allow create: if validChatReaderCursor(uid, readerUid);
        allow update: if resource.data.authorUid == uid
          && resource.data.readerUid == readerUid
          && request.resource.data.lastReadAt >= resource.data.lastReadAt
          && validChatReaderCursor(uid, readerUid);
        allow delete: if false;
      }
    }

    match /live/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /admin/{document} {
      allow read, write: if false;
    }
  }
}
